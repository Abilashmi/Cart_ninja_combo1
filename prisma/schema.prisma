generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Shopify Session ───────────────────────────────────────────────────────────

model Session {
  id                  String    @id @db.VarChar(191)
  shop                String    @db.VarChar(255)
  state               String    @db.VarChar(255)
  isOnline            Boolean   @default(false)
  scope               String?   @db.Text
  expires             DateTime?
  accessToken         String    @db.VarChar(255)
  userId              BigInt?
  firstName           String?   @db.VarChar(255)
  lastName            String?   @db.VarChar(255)
  email               String?   @db.VarChar(255)
  accountOwner        Boolean   @default(false)
  locale              String?   @db.VarChar(100)
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?   @db.VarChar(255)
  refreshTokenExpires DateTime?
}

// ─── Production Tables (live MySQL schema) ────────────────────────────────────

model Shop {
  id           Int      @id @default(autoincrement())
  shopDomain   String   @unique @map("shop_domain") @db.VarChar(255)
  accessToken  String?  @map("access_token") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  planName     String   @default("free") @map("plan_name") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  orderCount   Int      @default(0) @map("order_count")
  totalRevenue Decimal  @default(0.00) @map("total_revenue") @db.Decimal(12, 2)

  @@map("shops")
}

model CartDrawer {
  id                  Int      @id @default(autoincrement())
  shop                String   @unique @db.VarChar(255)
  cartStatus          Boolean  @default(true)
  progressData        String?  @map("progress_data") @db.LongText
  couponData          String?  @map("coupon_data") @db.LongText
  upsellData          String?  @map("upsell_data") @db.LongText
  progressStatus      Boolean  @default(false) @map("progress_status")
  couponStatus        Boolean  @default(false) @map("coupon_status")
  upsellStatus        Boolean  @default(false) @map("upsell_status")
  countdownData       String?  @map("countdown_data") @db.LongText
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  checkoutName        String?  @db.VarChar(255)
  checkoutFooterText  String?  @db.VarChar(500)
  customCSS           String?  @db.LongText
  checkoutButtonStyle String?  @map("checkout_button_style") @db.Text

  @@map("cart_drawer")
}

model CartClickEvent {
  id         Int      @id @default(autoincrement())
  shopId     String?  @map("shop_id") @db.VarChar(100)
  domain     String?  @db.VarChar(255)
  eventType  String?  @map("event_type") @db.VarChar(50)
  widgetType String?  @map("widget_type") @db.VarChar(100)
  sessionId  String?  @map("session_id") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  revenue    Decimal  @default(0.00) @db.Decimal(10, 2)

  @@map("cart_click_events")
}

model Coupon {
  id             Int      @id @default(autoincrement())
  internalId     String   @map("internal_id") @db.VarChar(100)
  shopifyId      String?  @map("shopify_id") @db.VarChar(100)
  shopDomain     String   @map("shop_domain") @db.VarChar(255)
  code           String   @db.VarChar(100)
  discountConfig String   @map("discount_config") @db.LongText
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([shopDomain], map: "idx_shop")
  @@index([code], map: "idx_code")
  @@map("coupons")
}

model CouponSliderWidget {
  id                     Int      @id @default(autoincrement())
  shopDomain             String   @unique @db.VarChar(255)
  temp1DefaultStyle      String?  @db.LongText
  temp2DefaultStyle      String?  @db.LongText
  temp3DefaultStyle      String?  @db.LongText
  selectedTemplate       String?  @db.VarChar(50)
  selectedTemplateCoupon String?  @db.LongText
  temp1CouponStyle       String?  @db.LongText
  temp2CouponStyle       String?  @db.LongText
  temp3CouponStyle       String?  @db.LongText
  temp1CouponCondition   String?  @db.LongText
  temp2CouponCondition   String?  @db.LongText
  temp3CouponCondition   String?  @db.LongText
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("coupon_slider_widget")
}

model FbtWidget {
  id             Int      @id @default(autoincrement())
  shopDomain     String   @unique @db.VarChar(255)
  temp1          String?  @db.LongText
  temp2          String?  @db.LongText
  temp3          String?  @db.LongText
  selectedTemp   String?  @db.VarChar(50)
  selectedMode   String?  @db.VarChar(50)
  condition      String?  @db.LongText
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  aiEnabled      Boolean  @default(false) @map("ai_enabled")
  aiProductCount Int      @default(0) @map("ai_product_count")

  @@map("fbt_widget")
}

// ─── Local App Models ──────────────────────────────────────────────────────────

model UpsellRule {
  id                  String   @id @default(uuid()) @db.VarChar(36)
  shop                String   @db.VarChar(255)
  name                String?  @db.VarChar(255)
  enabled             Boolean  @default(true)
  ruleType            String   @db.VarChar(50)
  priority            Int      @default(0)
  triggerProducts     String?  @db.LongText
  triggerCollections  String?  @db.LongText
  upsellProducts      String?  @db.LongText
  upsellCollections   String?  @db.LongText
  excludedProducts    String?  @db.LongText
  excludedCollections String?  @db.LongText
  cartValueThreshold  Int?     @default(0)
  displayLimit        Int      @default(3)
  layout              String   @default("slider") @db.VarChar(50)
  buttonText          String   @default("Add to Cart") @db.VarChar(255)
  showPrice           Boolean  @default(true)
  title               String   @default("Recommended for you") @db.VarChar(255)
  trackViews          Boolean  @default(true)
  trackClicks         Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([shop])
  @@index([ruleType])
  @@map("upsell_rules")
}

model WidgetSettings {
  id          String   @id @default(uuid()) @db.VarChar(36)
  shop        String   @unique @db.VarChar(255)
  coupons     String   @db.LongText
  fbt         String   @db.LongText
  progressBar String?  @db.LongText
  upsell      String?  @db.LongText
  updatedAt   DateTime @updatedAt
}

// ─── Combo Forge Models ────────────────────────────────────────────────────────
// NOTE: combo_templates / combo_analytics are raw-SQL tables (see
// prisma/migrations/20260618000003_create_combo_forge_tables), not managed by
// Prisma models here — that migration explicitly drops the orphaned
// `comboanalytic`/`combotemplate` tables these models used to generate.
// Do not re-add ComboTemplate/ComboAnalytic models; use getDb() raw queries.

model ComboSubscription {
  id               String    @id @default(uuid()) @db.VarChar(36)
  shop             String    @unique @db.VarChar(255)
  planId           String    @default("basic") @db.VarChar(50)
  shopifySubId     String?   @db.VarChar(255)
  status           String    @default("active") @db.VarChar(50)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shop])
}

model ComboAIUsage {
  id        String   @id @default(uuid()) @db.VarChar(36)
  shop      String   @db.VarChar(255)
  field     String   @db.VarChar(100)
  model     String   @default("gpt-4o-mini") @db.VarChar(100)
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  usedAt    DateTime @default(now())

  @@index([shop])
  @@index([usedAt])
}
